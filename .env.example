# Copy to .env and fill in. Never commit the real .env.

# Google Gemini API key (used for extraction). Free tier works:
# create one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...

# Optional: override the model (defaults to gemini-2.5-flash)
# CT_MODEL=gemini-2.5-flash

# Where the dataset lives
# CT_CSV_PATH=conferences.csv

# Optional: URL behind the site's "Submit your CFP" button (e.g. a Tally form
# that accepts a PDF/Word upload). Hidden when unset. In GitHub Actions, set
# this as a repository *variable* named CT_SUBMISSION_URL so every page rebuild
# keeps the button.
# CT_SUBMISSION_URL=https://tally.so/r/your-form

# --- Mailbox (IMAP) for the email source ---
CT_MAIL_HOST=imap.gmail.com
CT_MAIL_PORT=993
CT_MAIL_USER=academicaiagent@gmail.com
# For Gmail, use an App Password (not your account password).
CT_MAIL_PASSWORD=your-app-password
CT_MAIL_FOLDER=INBOX
# Process only unread messages and mark them read (recommended for routine runs).
CT_MAIL_UNSEEN_ONLY=true
CT_MAIL_USE_SSL=true
